# ──────────────────────────────────────────────
# TuneN2 Backend — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Application
NODE_ENV=development          # development | staging | production
PORT=3001                     # Server port

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/tunen2_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_ACCESS_SECRET=            # Required — secret for signing access tokens
JWT_REFRESH_SECRET=           # Required — secret for signing refresh tokens
JWT_ACCESS_EXPIRY=15m         # Access token TTL
JWT_REFRESH_EXPIRY=30d        # Refresh token TTL

# Stripe Payments
STRIPE_SECRET_KEY=            # Required — Stripe secret key (sk_test_... or sk_live_...)
STRIPE_WEBHOOK_SECRET=        # Required — Stripe webhook signing secret (whsec_...)

# AWS / S3 / CloudFront
AWS_REGION=us-east-1
AWS_S3_AUDIO_BUCKET=          # S3 bucket for audio files
AWS_S3_IMAGE_BUCKET=          # S3 bucket for images (artwork, avatars)
AWS_CLOUDFRONT_DOMAIN=        # CloudFront distribution domain
AWS_CLOUDFRONT_KEY_PAIR_ID=   # CloudFront key pair ID for signed URLs
AWS_ACCESS_KEY_ID=            # From AWS IAM user
AWS_SECRET_ACCESS_KEY=        # From AWS IAM user
AWS_CLOUDFRONT_PRIVATE_KEY=   # CloudFront private key (.pem contents) — use \n for newlines

# Email (Resend)
RESEND_API_KEY=               # Optional in dev (logs to console), required in production
EMAIL_FROM=TuneN2 <noreply@tunen2.com>

# Frontend URLs (CORS origins)
FRONTEND_URL=http://localhost:8081
ADMIN_URL=http://localhost:5173

# App URL (for deep links / verification emails)
APP_URL=http://localhost:8081

# Optional: Google OAuth (Step 7 in setup.md)
GOOGLE_CLIENT_ID=            # From Google Cloud Console
GOOGLE_CLIENT_SECRET=        # From Google Cloud Console