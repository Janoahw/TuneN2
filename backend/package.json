    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.24.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.6.0",
