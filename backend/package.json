    "bcryptjs": "^2.4.3",
    "bullmq": "^5.30.0",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.0",
    "nanoid": "^5.0.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "stripe": "^17.7.0",
    "zod": "^3.24.0"
