generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS ───────────────────────────────────────────────

model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String   @unique @db.VarChar(255)
  passwordHash   String?  @map("password_hash") @db.VarChar(255)
  displayName    String   @map("display_name") @db.VarChar(100)
  avatarUrl      String?  @map("avatar_url") @db.VarChar(500)
  authProvider   String   @default("email") @map("auth_provider") @db.VarChar(20)
  authProviderId String?  @map("auth_provider_id") @db.VarChar(255)
  emailVerified  Boolean  @default(false) @map("email_verified")
  isArtist       Boolean  @default(false) @map("is_artist")
  isAdmin        Boolean  @default(false) @map("is_admin")
  isBanned       Boolean  @default(false) @map("is_banned")
  stripeCustomerId String?  @map("stripe_customer_id") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  artistProfile  ArtistProfile?
  purchases      Purchase[]
  follows        Follow[]
  downloads      Download[]
  notifications  Notification[]
  contentReports ContentReport[] @relation("reporter")
  reviewedReports ContentReport[] @relation("reviewer")
  emailOtps       EmailOTP[]
  passwordResets  PasswordReset[]

  @@index([email])
  @@map("users")
}

// ─── EMAIL OTP ───────────────────────────────────────────

model EmailOTP {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  code      String   @db.VarChar(10) // 6-digit OTP code
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  attempts  Int      @default(0) // Number of failed verification attempts
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId])
  @@index([expiresAt])
  @@map("email_otps")
}

// ─── PASSWORD RESETS ─────────────────────────────────────

model PasswordReset {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_resets")
}

// ─── ARTIST PROFILES ─────────────────────────────────────

model ArtistProfile {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  artistName           String   @map("artist_name") @db.VarChar(100)
  bio                  String?  @db.Text
  genreIds             Int[]    @map("genre_ids")
  profileImageUrl      String?  @map("profile_image_url") @db.VarChar(500)
  bannerImageUrl       String?  @map("banner_image_url") @db.VarChar(500)
  collaborationPrice   Decimal? @map("collaboration_price") @db.Decimal(10, 2)
  fanSubscriptionPrice Decimal? @map("fan_subscription_price") @db.Decimal(10, 2)
  stripeAccountId      String?  @map("stripe_account_id") @db.VarChar(255)
  subscriptionStatus   String   @default("active") @map("subscription_status") @db.VarChar(20)
  isVerified           Boolean  @default(false) @map("is_verified")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  releases           Release[]
  songs              Song[]
  purchases          Purchase[]
  follows            Follow[]
  wallet             Wallet?
  contentReports     ContentReport[]

  @@index([userId])
  @@index([subscriptionStatus])
  @@map("artist_profiles")
}

// ─── GENRES ──────────────────────────────────────────────

model Genre {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)
  slug String @unique @db.VarChar(50)

  songs Song[]

  @@map("genres")
}

// ─── RELEASES ────────────────────────────────────────────

model Release {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  artistId    String   @map("artist_id") @db.Uuid
  title       String   @db.VarChar(200)
  type        String   @db.VarChar(10) // 'single' | 'album' | 'ep'
  coverArtUrl String   @map("cover_art_url") @db.VarChar(500)
  releaseDate DateTime? @map("release_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  artist ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  songs  Song[]

  @@index([artistId])
  @@map("releases")
}

// ─── SONGS ───────────────────────────────────────────────

model Song {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  releaseId       String?  @map("release_id") @db.Uuid
  artistId        String   @map("artist_id") @db.Uuid
  title           String   @db.VarChar(200)
  description     String?  @db.Text
  durationSeconds Int?     @map("duration_seconds")
  genreId         Int?     @map("genre_id")
  price           Decimal  @default(0.00) @db.Decimal(10, 2)
  isFree          Boolean  @default(false) @map("is_free")
  audioUrl        String   @map("audio_url") @db.VarChar(500) // S3 key (original)
  streamUrl       String?  @map("stream_url") @db.VarChar(500) // S3 key (transcoded AAC)
  coverArtUrl     String?  @map("cover_art_url") @db.VarChar(500)
  lyrics          String?  @db.Text
  trackNumber     Int      @default(1) @map("track_number")
  streamCount     BigInt   @default(0) @map("stream_count")
  status          String   @default("processing") @db.VarChar(20) // 'processing'|'active'|'rejected'|'deleted'
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  release        Release?       @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  artist         ArtistProfile  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre          Genre?         @relation(fields: [genreId], references: [id])
  purchases      Purchase[]
  downloads      Download[]
  contentReports ContentReport[]

  @@index([artistId])
  @@index([genreId])
  @@index([status])
  @@map("songs")
}

// ─── PURCHASES ───────────────────────────────────────────

model Purchase {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyerId         String   @map("buyer_id") @db.Uuid
  songId          String   @map("song_id") @db.Uuid
  artistId        String   @map("artist_id") @db.Uuid
  amount          Decimal  @db.Decimal(10, 2)
  platformFee     Decimal  @map("platform_fee") @db.Decimal(10, 2)
  artistEarnings  Decimal  @map("artist_earnings") @db.Decimal(10, 2)
  stripePaymentId String   @map("stripe_payment_id") @db.VarChar(255)
  status          String   @default("completed") @db.VarChar(20) // 'pending'|'completed'|'failed'|'refunded'
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  buyer  User          @relation(fields: [buyerId], references: [id])
  song   Song          @relation(fields: [songId], references: [id])
  artist ArtistProfile @relation(fields: [artistId], references: [id])

  @@unique([buyerId, songId])
  @@index([buyerId])
  @@index([artistId])
  @@map("purchases")
}

// ─── DOWNLOADS ───────────────────────────────────────────

model Download {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  songId        String   @map("song_id") @db.Uuid
  fileSizeBytes Int?     @map("file_size_bytes")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])
  song Song @relation(fields: [songId], references: [id])

  @@index([userId])
  @@index([songId])
  @@map("downloads")
}

// ─── FOLLOWS ─────────────────────────────────────────────

model Follow {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followerId String   @map("follower_id") @db.Uuid
  artistId   String   @map("artist_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  follower User          @relation(fields: [followerId], references: [id], onDelete: Cascade)
  artist   ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([followerId, artistId])
  @@index([artistId])
  @@map("follows")
}

// ─── WALLETS ─────────────────────────────────────────────

model Wallet {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  artistId       String   @unique @map("artist_id") @db.Uuid
  balance        Decimal  @default(0.00) @db.Decimal(12, 2)
  totalEarned    Decimal  @default(0.00) @map("total_earned") @db.Decimal(12, 2)
  totalWithdrawn Decimal  @default(0.00) @map("total_withdrawn") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  artist       ArtistProfile       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  withdrawals  Withdrawal[]

  @@map("wallets")
}

// ─── WITHDRAWALS ─────────────────────────────────────────

model Withdrawal {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId         String    @map("wallet_id") @db.Uuid
  amountCents      Int       @map("amount_cents")
  feeCents         Int       @default(0) @map("fee_cents")
  netAmountCents   Int       @map("net_amount_cents")
  stripeTransferId String?   @map("stripe_transfer_id") @db.VarChar(255)
  status           String    @default("pending") @db.VarChar(20) // 'pending'|'processing'|'completed'|'failed'
  requestedAt      DateTime  @default(now()) @map("requested_at") @db.Timestamptz()
  completedAt      DateTime? @map("completed_at") @db.Timestamptz()

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([status])
  @@map("withdrawals")
}

// ─── PROCESSED WEBHOOKS (idempotency) ────────────────────

model ProcessedWebhook {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stripeEventId String  @unique @map("stripe_event_id") @db.VarChar(255)
  eventType    String   @map("event_type") @db.VarChar(100)
  processedAt  DateTime @default(now()) @map("processed_at") @db.Timestamptz()

  @@index([stripeEventId])
  @@map("processed_webhooks")
}

// ─── WALLET TRANSACTIONS ─────────────────────────────────

model WalletTransaction {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId         String   @map("wallet_id") @db.Uuid
  type             String   @db.VarChar(20) // 'song_sale'|'subscription_earning'|'collaboration'|'withdrawal'
  amount           Decimal  @db.Decimal(10, 2) // positive = credit, negative = debit
  fee              Decimal  @default(0.00) @db.Decimal(10, 2)
  netAmount        Decimal  @map("net_amount") @db.Decimal(10, 2)
  referenceId      String?  @map("reference_id") @db.Uuid
  referenceType    String?  @map("reference_type") @db.VarChar(30)
  stripeTransferId String?  @map("stripe_transfer_id") @db.VarChar(255)
  status           String   @default("completed") @db.VarChar(20) // 'pending'|'completed'|'failed'
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([type])
  @@map("wallet_transactions")
}

// ─── NOTIFICATIONS ───────────────────────────────────────

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  body      String?  @db.Text
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

// ─── CONTENT REPORTS ─────────────────────────────────────

model ContentReport {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId  String    @map("reporter_id") @db.Uuid
  songId      String?   @map("song_id") @db.Uuid
  artistId    String?   @map("artist_id") @db.Uuid
  reason      String    @db.VarChar(50) // 'copyright'|'inappropriate'|'spam'|'other'
  description String?   @db.Text
  status      String    @default("pending") @db.VarChar(20) // 'pending'|'reviewed'|'resolved'|'dismissed'
  reviewedBy  String?   @map("reviewed_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz()

  reporter User           @relation("reporter", fields: [reporterId], references: [id])
  reviewer User?          @relation("reviewer", fields: [reviewedBy], references: [id])
  song     Song?          @relation(fields: [songId], references: [id])
  artist   ArtistProfile? @relation(fields: [artistId], references: [id])

  @@map("content_reports")
}
